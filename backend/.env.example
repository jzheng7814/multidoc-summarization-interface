# Backend configuration
MULTI_DOCUMENT_APP_NAME=multi-document-backend
MULTI_DOCUMENT_ENVIRONMENT=development
MULTI_DOCUMENT_DATABASE_URL=sqlite:///./app/data/legal_case.db
MULTI_DOCUMENT_EVENT_LOG_DIR=logs
MULTI_DOCUMENT_EVENT_LOG_PREFIX=events
MULTI_DOCUMENT_IPC_SOCKET_PATH=/tmp/gavel_tool.sock
MULTI_DOCUMENT_CLUSTER_RUN_MODE=remote
MULTI_DOCUMENT_CLUSTER_SPOOF_EVENT_DELAY_SECONDS=0.0
MULTI_DOCUMENT_CLUSTER_SPOOF_EXTRACTION_FIXTURE_DIR=../scratch/handoff/spoof_fixtures/extraction/run_20260317T222144Z_124c78addb
MULTI_DOCUMENT_CLUSTER_SPOOF_SUMMARY_FIXTURE_DIR=../scratch/handoff/spoof_fixtures/summary/run_20260319T025055Z_6dcb90725b
MULTI_DOCUMENT_CLUSTER_SSH_HOST=sky1
# Replace <username> with your real cluster username. These values are read literally,
# not through a shell, so .env entries must use concrete absolute paths in real runs.
MULTI_DOCUMENT_CLUSTER_REMOTE_STAGE_ROOT=/coc/pskynet6/<username>/flash/interface_agent_runs
MULTI_DOCUMENT_CLUSTER_REMOTE_PYTHON_PATH=/coc/pskynet6/<username>/flash/miniconda3/envs/gavel-dev/bin/python
MULTI_DOCUMENT_CLUSTER_REMOTE_HF_CACHE_DIR=/coc/pskynet6/<username>/flash/hf_cache
MULTI_DOCUMENT_CLUSTER_REMOTE_SLURM_BIN_DIR=/opt/slurm/Ubuntu-20.04/current/bin
MULTI_DOCUMENT_CLUSTER_REMOTE_CONTROLLER_SCRIPT=interface_agents/checklist_agent/controller/run_controller_native.py
MULTI_DOCUMENT_CLUSTER_POLL_SECONDS=2
MULTI_DOCUMENT_CLUSTER_MAX_WAIT_SECONDS=21600
MULTI_DOCUMENT_CLUSTER_MODEL_NAME=unsloth/gpt-oss-20b-BF16
MULTI_DOCUMENT_CLUSTER_CHECKLIST_SPEC_PATH=app/resources/checklists/remote_checklist_spec.individual.json
MULTI_DOCUMENT_CLUSTER_FOCUS_CONTEXT_TEMPLATE_PATH=app/resources/checklists/focus_context.template.txt
MULTI_DOCUMENT_CLUSTER_RESUME=false
MULTI_DOCUMENT_CLUSTER_DEBUG=false
MULTI_DOCUMENT_CLUSTER_SLURM_PARTITION=slurm-partition
MULTI_DOCUMENT_CLUSTER_SLURM_QOS=slurm-qos
MULTI_DOCUMENT_CLUSTER_SUMMARY_REMOTE_CONTROLLER_SCRIPT=interface_agents/summary_agent/controller/run_controller.py
MULTI_DOCUMENT_CLUSTER_SUMMARY_MODEL_NAME=unsloth/gpt-oss-20b-BF16
MULTI_DOCUMENT_CLUSTER_SUMMARY_MAX_STEPS=200
MULTI_DOCUMENT_CLUSTER_SUMMARY_REASONING_EFFORT=medium
MULTI_DOCUMENT_CLUSTER_SUMMARY_K_RECENT_TOOL_OUTPUTS=5
MULTI_DOCUMENT_CLUSTER_SUMMARY_PROMPT_CONFIG=
MULTI_DOCUMENT_CLUSTER_SUMMARY_FOCUS_CONTEXT_TEMPLATE_PATH=app/resources/summary/focus_context.template.txt
MULTI_DOCUMENT_CLUSTER_SUMMARY_SLURM_PARTITION=nlprx-lab
MULTI_DOCUMENT_CLUSTER_SUMMARY_SLURM_QOS=short
