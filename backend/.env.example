# Backend configuration
LEGAL_CASE_APP_NAME=legal-case-backend
LEGAL_CASE_ENVIRONMENT=development
LEGAL_CASE_USE_MOCK_LLM=false
LEGAL_CASE_CONFIG_PATH=config/app.config.json
LEGAL_CASE_DATABASE_URL=sqlite:///./app/data/legal_case.db
# Temporary safety switch for local validation: when false, checklist starts return failed status unless cached.
LEGAL_CASE_CHECKLIST_START_ENABLED=true
LEGAL_CASE_CLUSTER_RUN_MODE=remote
LEGAL_CASE_CLUSTER_SPOOF_EVENT_DELAY_SECONDS=0.0
LEGAL_CASE_CLUSTER_SPOOF_EXTRACTION_FIXTURE_DIR=../scratch/handoff/spoof_fixtures/extraction/run_20260317T222144Z_124c78addb
LEGAL_CASE_CLUSTER_SPOOF_SUMMARY_FIXTURE_DIR=../scratch/handoff/spoof_fixtures/summary/run_20260319T025055Z_6dcb90725b
LEGAL_CASE_CLUSTER_SSH_HOST=sky1
LEGAL_CASE_CLUSTER_REMOTE_STAGE_ROOT=/coc/pskynet6/$USER/flash/interface_agent_runs
LEGAL_CASE_CLUSTER_REMOTE_PYTHON_PATH=/coc/pskynet6/$USER/flash/miniconda3/envs/gavel-dev/bin/python
LEGAL_CASE_CLUSTER_REMOTE_HF_CACHE_DIR=/coc/pskynet6/$USER/flash/hf_cache
LEGAL_CASE_CLUSTER_REMOTE_SLURM_BIN_DIR=/opt/slurm/Ubuntu-20.04/current/bin
LEGAL_CASE_CLUSTER_REMOTE_CONTROLLER_SCRIPT=interface_agents/checklist_agent/controller/run_controller_native.py
LEGAL_CASE_CLUSTER_POLL_SECONDS=2
LEGAL_CASE_CLUSTER_MAX_WAIT_SECONDS=21600
LEGAL_CASE_CLUSTER_MODEL_NAME=unsloth/gpt-oss-20b-BF16
LEGAL_CASE_CLUSTER_CHECKLIST_STRATEGY=individual
LEGAL_CASE_CLUSTER_CHECKLIST_SPEC_PATH=app/resources/checklists/remote_checklist_spec.individual.json
LEGAL_CASE_CLUSTER_FOCUS_CONTEXT_TEMPLATE_PATH=app/resources/checklists/focus_context.template.txt
LEGAL_CASE_CLUSTER_MAX_STEPS=300
LEGAL_CASE_CLUSTER_RESUME=false
LEGAL_CASE_CLUSTER_DEBUG=false
LEGAL_CASE_CLUSTER_OUTPUT_BASE_DIR=output_controller
LEGAL_CASE_CLUSTER_DATASET_PREFIX=controller
LEGAL_CASE_CLUSTER_SLURM_PARTITION=slurm-partition
LEGAL_CASE_CLUSTER_SLURM_QOS=slurm-qos
LEGAL_CASE_CLUSTER_SUMMARY_REMOTE_CONTROLLER_SCRIPT=interface_agents/summary_agent/controller/run_controller.py
LEGAL_CASE_CLUSTER_SUMMARY_MODEL_NAME=unsloth/gpt-oss-20b-BF16
LEGAL_CASE_CLUSTER_SUMMARY_MAX_STEPS=200
LEGAL_CASE_CLUSTER_SUMMARY_REASONING_EFFORT=medium
LEGAL_CASE_CLUSTER_SUMMARY_K_RECENT_TOOL_OUTPUTS=5
LEGAL_CASE_CLUSTER_SUMMARY_PROMPT_CONFIG=
LEGAL_CASE_CLUSTER_SUMMARY_FOCUS_CONTEXT_TEMPLATE_PATH=app/resources/summary/focus_context.template.txt
LEGAL_CASE_CLUSTER_SUMMARY_SLURM_PARTITION=nlprx-lab
LEGAL_CASE_CLUSTER_SUMMARY_SLURM_QOS=short

# Secret keys should stay outside version control.
OPENAI_API_KEY=key
CLEARINGHOUSE_API_KEY=key
