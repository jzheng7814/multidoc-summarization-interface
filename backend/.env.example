# Backend configuration
LEGAL_CASE_APP_NAME=legal-case-backend
LEGAL_CASE_ENVIRONMENT=development
LEGAL_CASE_USE_MOCK_LLM=false
LEGAL_CASE_CONFIG_PATH=config/app.config.json
LEGAL_CASE_DATABASE_URL=sqlite:///./app/data/legal_case.db
LEGAL_CASE_CHECKLIST_EXTRACTION_MODE=cluster
# Temporary safety switch for local validation: when false, checklist starts return failed status unless cached.
LEGAL_CASE_CHECKLIST_START_ENABLED=true
LEGAL_CASE_CLUSTER_SSH_HOST=sky1
LEGAL_CASE_CLUSTER_REMOTE_REPO_DIR=/path/to/remote
LEGAL_CASE_CLUSTER_REMOTE_PYTHON_PATH=/path/to/remote-python
LEGAL_CASE_CLUSTER_REMOTE_CONTROLLER_SCRIPT=/path/to/remote-controller
LEGAL_CASE_CLUSTER_POLL_SECONDS=2
LEGAL_CASE_CLUSTER_MAX_WAIT_SECONDS=21600
LEGAL_CASE_CLUSTER_MODEL_NAME=unsloth/gpt-oss-20b-BF16
LEGAL_CASE_CLUSTER_CHECKLIST_CONFIG=/path/to/checklist-config
LEGAL_CASE_CLUSTER_MAX_STEPS=300
LEGAL_CASE_CLUSTER_RESUME=false
LEGAL_CASE_CLUSTER_DEBUG=false
LEGAL_CASE_CLUSTER_OUTPUT_BASE_DIR=output_controller
LEGAL_CASE_CLUSTER_DATASET_PREFIX=controller
LEGAL_CASE_CLUSTER_SLURM_PARTITION=slurm-partition
LEGAL_CASE_CLUSTER_SLURM_QOS=slurm-qos

# Secret keys should stay outside version control.
OPENAI_API_KEY=key
CLEARINGHOUSE_API_KEY=key
