# Runtime configuration for a staged checklist-agent snapshot.
# In the normal backend workflow, this file is generated automatically inside
# each staged run directory before the controller launches.

INTERFACE_AGENT_BASE_DIR=/coc/pskynet6/$USER/flash/interface_agent_runs/<backend-run-id>/interface_agents/checklist_agent
INTERFACE_AGENT_PYTHON_BIN=/coc/pskynet6/$USER/flash/miniconda3/envs/gavel-dev/bin/python
INTERFACE_AGENT_SLURM_BIN_DIR=/opt/slurm/Ubuntu-20.04/current/bin

INTERFACE_AGENT_HF_HOME=/coc/pskynet6/$USER/flash/hf_cache
INTERFACE_AGENT_HUGGINGFACE_HUB_CACHE=/coc/pskynet6/$USER/flash/hf_cache/hub
INTERFACE_AGENT_TRANSFORMERS_CACHE=/coc/pskynet6/$USER/flash/hf_cache/hub

# Optional overrides:
# INTERFACE_AGENT_RUNS_BASE=/coc/pskynet6/$USER/flash/interface_agent_runs/<backend-run-id>/interface_agents/checklist_agent/controller/runs
# INTERFACE_AGENT_SBATCH_SCRIPT=/coc/pskynet6/$USER/flash/interface_agent_runs/<backend-run-id>/interface_agents/checklist_agent/run_agent.sbatch
